---
---
<div class="export-buttons">
  <span class="book-sidebar-label">Download As</span>

  <button class="export-btn" onclick="download('docx')">
    <span class="export-icon">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
    </span>
    <span class="export-label">Word Document</span>
    <span class="export-ext">.docx</span>
  </button>

  <button class="export-btn" onclick="download('pdf')">
    <span class="export-icon">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="9" y1="13" x2="15" y2="13"/>
        <line x1="9" y1="17" x2="15" y2="17"/>
      </svg>
    </span>
    <span class="export-label">PDF</span>
    <span class="export-ext">.pdf</span>
  </button>

  <button class="export-btn export-btn--gold" onclick="download('pptx')">
    <span class="export-icon">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </span>
    <span class="export-label">Presentation</span>
    <span class="export-ext">.pptx</span>
  </button>
</div>

<style>
  .export-buttons {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #2e5233;
  }

  .export-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1px solid #2e5233;
    padding: 10px 14px;
    margin-bottom: 8px;
    cursor: pointer;
    color: #b8b3a0;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s;
  }

  .export-btn:hover {
    border-color: #c9a84c;
    color: #f0ece0;
  }

  .export-btn:hover .export-icon {
    color: #c9a84c;
  }

  .export-btn--gold {
    border-color: #3a5a30;
    background: #2a4e30;
  }

  .export-btn--gold:hover {
    background: #2e5233;
  }

  .export-icon {
    color: #4a6a4c;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .export-label {
    flex: 1;
    text-align: left;
  }

  .export-ext {
    color: #4a6a4c;
    font-size: 9px;
    letter-spacing: .1em;
  }
</style>

<script is:inline>
  window.download = function (format) {
    console.log("DOWNLOAD FUNCTION CALLED");

    const pathParts = window.location.pathname
      .split("/")
      .filter(Boolean);

    const slug = pathParts[pathParts.length - 1];

    console.log("DOWNLOAD CLICK:", { slug, format });

    if (!slug || !format) {
      console.error("Missing slug or format");
      return;
    }

    const url = `/api/export?slug=${encodeURIComponent(
      slug
    )}&format=${encodeURIComponent(format)}`;

    console.log("FINAL URL:", url);

    window.location.href = url;
  };
</script>