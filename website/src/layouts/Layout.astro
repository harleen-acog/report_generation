---
import "../styles/global.css"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Author CLI</title>
     <style is:global>
    .markdown {
      max-width: 70ch;
      line-height: 1.7;
      font-size: 1.05rem;
    }

    .markdown h1 {
      font-size: 2rem;
      margin-top: 2rem;
    }

    .markdown h2 {
      font-size: 1.5rem;
      margin-top: 1.5rem;
    }

    .markdown p {
      margin: 1rem 0;
    }

    .markdown ul {
      padding-left: 1.25rem;
      list-style: disc;
    }

    .markdown blockquote {
      border-left: 4px solid #ddd;
      padding-left: 1rem;
      color: #666;
    }
  </style>
  </head>

  <body class="bg-white text-gray-900 font-sans">
    <header class="border-b">
      <div class="max-w-5xl mx-auto p-4 flex justify-between items-center">
        <a href="/books" class="font-bold text-lg">
          Author CLI
        </a>

        <nav class="text-sm text-gray-600">
          <a href="/books" class="mr-4">Books</a>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto p-6">
      <slot />
    </main>
  </body>
</html>