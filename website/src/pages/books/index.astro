---
import Layout from "../../layouts/Layout.astro";
import BookCard from "../../components/BookCard.astro";
import { getCollection } from "astro:content";

const books = await getCollection("books");

const sorted = books.sort(
  (a, b) =>
    (b.data.generatedAt?.getTime?.() ?? 0) -
    (a.data.generatedAt?.getTime?.() ?? 0)
);
---

<Layout>
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Generated Books</h1>
    <p class="text-gray-500">AI-generated library from Author CLI</p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    {sorted.map((book) => (
      <BookCard book={book} />
    ))}
  </div>
</Layout>