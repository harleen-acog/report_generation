---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
import { getAllReports, getReportsByType, getMockReports } from "../lib/reports";

let diseaseReports = getReportsByType("disease_report");
let bookReports = getReportsByType("book_report");

// fallback to mock data in dev if no output files yet
if (diseaseReports.length === 0 && bookReports.length === 0) {
  const mocks = getMockReports();
  diseaseReports = mocks.filter(r => r.report_type === "disease_report");
  bookReports = mocks.filter(r => r.report_type === "book_report");
}
---

<Base title="Report Viewer — AI Research Reports">
  <div class="min-h-screen bg-ink-50">

    <!-- Header -->
    <header class="border-b border-ink-200 bg-ink-50/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-sm bg-ink-950 flex items-center justify-center">
            <span class="text-ink-50 text-xs font-mono font-bold">R</span>
          </div>
          <span class="font-display text-lg font-semibold text-ink-950 tracking-tight">
            Report Viewer
          </span>
        </div>
        <span class="text-xs text-ink-400 font-mono tracking-widest uppercase">
          AI-Generated Reports
        </span>
      </div>
    </header>

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
      <div class="animate-fade-up">
        <p class="text-xs font-mono tracking-widest text-ink-400 uppercase mb-4">
          Research Intelligence
        </p>
        <h1 class="font-display text-5xl font-bold text-ink-950 leading-tight mb-4">
          Your Reports,<br/>
          <span class="text-ink-400 font-normal italic">beautifully rendered.</span>
        </h1>
        <p class="text-ink-500 text-lg max-w-xl leading-relaxed">
          AI-generated disease landscape reports and literary analyses — 
          structured, searchable, and ready to explore.
        </p>
      </div>
    </section>

    <!-- Report Type Tabs -->
    <section class="max-w-6xl mx-auto px-6" id="reports">
      <!-- Tab switcher -->
      <div class="flex gap-0 border-b border-ink-200 mb-10" id="tab-container">
        <button
          id="tab-disease"
          onclick="switchTab('disease')"
          class="report-tab active-pharma text-pharma-700"
          data-tab="disease"
        >
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Disease Reports
            <span class="ml-1 text-xs bg-pharma-100 text-pharma-700 px-2 py-0.5 rounded-full font-medium">
              {diseaseReports.length}
            </span>
          </span>
        </button>
        <button
          id="tab-book"
          onclick="switchTab('book')"
          class="report-tab text-ink-400 hover:text-ink-700"
          data-tab="book"
        >
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            Book Reports
            <span class="ml-1 text-xs bg-literary-100 text-literary-700 px-2 py-0.5 rounded-full font-medium">
              {bookReports.length}
            </span>
          </span>
        </button>
      </div>

      <!-- Disease Reports Grid -->
      <div id="panel-disease" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 animate-fade-up">
        {diseaseReports.map((report, i) => (
          <a
            href={`/disease/${report.slug}`}
            class="report-card group block bg-white border border-ink-200 rounded-lg p-6 hover:border-pharma-300"
            style={`animation-delay: ${i * 0.08}s`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 rounded-md bg-pharma-50 border border-pharma-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-pharma-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <span class="text-xs font-mono text-ink-300 group-hover:text-pharma-400 transition-colors">
                →
              </span>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink-950 mb-1 group-hover:text-pharma-800 transition-colors">
              {report.name}
            </h3>
            <p class="text-xs text-ink-400 font-mono">
              Disease Landscape Report
            </p>
            {report.generated_at && (
              <p class="text-xs text-ink-300 mt-3 pt-3 border-t border-ink-100">
                {new Date(report.generated_at).toLocaleDateString("en-GB", {
                  day: "numeric", month: "short", year: "numeric"
                })}
              </p>
            )}
          </a>
        ))}

        {diseaseReports.length === 0 && (
          <div class="col-span-3 text-center py-20">
            <p class="text-ink-300 font-display text-2xl mb-2">No reports yet</p>
            <p class="text-ink-400 text-sm">
              Run <code class="font-mono bg-ink-100 px-2 py-0.5 rounded">author-cli report --report-type disease_report --name "Disease"</code> to generate one
            </p>
          </div>
        )}
      </div>

      <!-- Book Reports Grid -->
      <div id="panel-book" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 animate-fade-up">
        {bookReports.map((report, i) => (
          <a
            href={`/book/${report.slug}`}
            class="report-card group block bg-white border border-ink-200 rounded-lg p-6 hover:border-literary-300"
            style={`animation-delay: ${i * 0.08}s`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 rounded-md bg-literary-50 border border-literary-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-literary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
              <span class="text-xs font-mono text-ink-300 group-hover:text-literary-400 transition-colors">
                →
              </span>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink-950 mb-1 group-hover:text-literary-800 transition-colors">
              {report.name}
            </h3>
            {report.author && (
              <p class="text-sm text-ink-500 italic mb-1">by {report.author}</p>
            )}
            <p class="text-xs text-ink-400 font-mono">Book Report</p>
            {report.generated_at && (
              <p class="text-xs text-ink-300 mt-3 pt-3 border-t border-ink-100">
                {new Date(report.generated_at).toLocaleDateString("en-GB", {
                  day: "numeric", month: "short", year: "numeric"
                })}
              </p>
            )}
          </a>
        ))}

        {bookReports.length === 0 && (
          <div class="col-span-3 text-center py-20">
            <p class="text-ink-300 font-display text-2xl mb-2">No book reports yet</p>
            <p class="text-ink-400 text-sm">
              Run <code class="font-mono bg-ink-100 px-2 py-0.5 rounded">author-cli report --report-type book_report --name "Title" --author "Author"</code>
            </p>
          </div>
        )}
      </div>
    </section>

    <!-- Footer -->
    <footer class="max-w-6xl mx-auto px-6 py-12 mt-16 border-t border-ink-200">
      <div class="flex items-center justify-between">
        <span class="text-xs text-ink-300 font-mono">Report Viewer</span>
        <span class="text-xs text-ink-300 font-mono">AI-generated · Not for clinical use</span>
      </div>
    </footer>
  </div>
</Base>

<script>
  function switchTab(tab: string) {
    const diseasePanel = document.getElementById('panel-disease');
    const bookPanel = document.getElementById('panel-book');
    const diseaseTab = document.getElementById('tab-disease');
    const bookTab = document.getElementById('tab-book');

    if (!diseasePanel || !bookPanel || !diseaseTab || !bookTab) return;

    if (tab === 'disease') {
      diseasePanel.classList.remove('hidden');
      bookPanel.classList.add('hidden');
      diseaseTab.className = 'report-tab active-pharma text-pharma-700';
      bookTab.className = 'report-tab text-ink-400 hover:text-ink-700';
    } else {
      bookPanel.classList.remove('hidden');
      diseasePanel.classList.add('hidden');
      bookTab.className = 'report-tab active-literary text-literary-700';
      diseaseTab.className = 'report-tab text-ink-400 hover:text-ink-700';
    }
  }

  // expose globally for onclick handlers
  (window as any).switchTab = switchTab;
</script>
